// App-owned (read-write) database — Neon free tier (ADR 0003).
//
// This is the app's SECOND Prisma schema/client. The read-only nubebar
// read-model (issue #5) gets its own schema/client; the two never share a
// generated client. The generated client lands under `lib/db/app/generated`
// and must only be imported through the `lib/db/app` seam.
//
// Migrations connect via the DIRECT (unpooled) connection (`directUrl`);
// application runtime connects via the pooled PgBouncer connection through the
// `@prisma/adapter-pg` driver adapter wired up in `lib/db/app`.

generator client {
  provider = "prisma-client"
  output   = "../../lib/db/app/generated/client"
}

datasource db {
  provider = "postgresql"
}

/// Minimal initial table so the migration pipeline is real and runnable
/// (issue #4). The substantive app tables — Auth.js users/sessions (ADR 0002),
/// chat conversations/messages (ADR 0001/0004) — arrive in later slices.
/// Each row records a write to the app DB; the round-trip test and the
/// `/health` readout both exercise it end to end.
model HealthCheck {
  id        String   @id @default(uuid())
  note      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}

/// Auth.js v5 standard schema (issue #11 / ADR 0002), shaped per
/// `@auth/prisma-adapter`'s spec. `sucursalIds` is NOT stored here — it is
/// computed per-session by the `lib/auth` session callback from the
/// `UserSucursal` join table, which Slice 2 (#12) introduces. Sessions use
/// the JWT strategy, not the adapter's database-session default (see
/// `lib/auth/index.ts`'s top comment for why) — these tables still exist so
/// the adapter can persist `User`/`Account`/`VerificationToken` rows.
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts       Account[]
  sessions       Session[]
  userSucursales UserSucursal[]

  @@map("users")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

/// Sucursal scoping (issue #12 / ADR 0002): which Sucursales a User can see.
/// `sucursalId` mirrors `core_sucursal.id` in the nubebar read model, but
/// deliberately has NO cross-DB foreign key — the two databases stay
/// independent (ADR 0003). Validity is checked in application code
/// (`lib/auth.assignSucursales`) against `lib/db/nubebar` at assignment time.
model UserSucursal {
  userId     String   @map("user_id")
  sucursalId Int      @map("sucursal_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, sucursalId])
  @@map("user_sucursales")
}
