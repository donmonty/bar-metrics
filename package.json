{
  "name": "bar-metrics",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard + AI chatbot for nubebar bar managers",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma generate --config prisma.nubebar.config.ts && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "prisma generate && prisma generate --config prisma.nubebar.config.ts",
    "db:app:generate": "prisma generate",
    "db:app:migrate:dev": "prisma migrate dev",
    "db:app:migrate:deploy": "prisma migrate deploy",
    "db:app:studio": "prisma studio",
    "db:nubebar:pull": "prisma db pull --config prisma.nubebar.config.ts",
    "db:nubebar:generate": "prisma generate --config prisma.nubebar.config.ts",
    "db:app:assign-sucursales": "tsx scripts/assign-sucursales.ts",
    "db:app:assign-sucursales:prod": "bash scripts/assign-sucursales-prod.sh"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.2",
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "^15.5.19",
    "next-auth": "5.0.0-beta.31",
    "react": "19.1.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.1.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
